# Copy to .env and replace values appropriate for the environment.
# Do not commit a populated .env file.

ENVIRONMENT=development
# Production requires a unique value of at least 32 characters.
SECRET_KEY=change-this-to-a-unique-secret-before-production

POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=verisonic

REDIS_HOST=redis
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=verisonic-audio
S3_ENDPOINT_URL=http://minio:9000

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WEBRTC_BUFFER_SEC=3
TZ=UTC

# Optional: required only to accept Razorpay subscription payments.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: used for wallet withdrawal CSV email export.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
